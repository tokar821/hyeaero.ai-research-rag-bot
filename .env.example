# HyeAero Backend - RAG Pipeline Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
# Either provide connection string OR individual components
POSTGRES_CONNECTION_STRING=postgres://user:password@host:port/database?sslmode=require
# OR use individual components:
# POSTGRES_HOST=your-postgres-host
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=your-database-name
# POSTGRES_USER=your-postgres-user
# POSTGRES_PASSWORD=your-postgres-password

# ============================================================================
# Pinecone Configuration
# ============================================================================
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX_NAME=
PINECONE_DIMENSION=
PINECONE_METRIC=
PINECONE_REGION=

# ============================================================================
# OpenAI Configuration
# ============================================================================
OPENAI_API_KEY=
OPENAI_EMBEDDING_DIMENSION=

# ============================================================================
# RAG Pipeline Configuration (Optional - defaults shown)
# ============================================================================
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=200
# RAG_BATCH_SIZE=100
#
# BGE cross-encoder rerank (sentence-transformers + PyTorch). Default in code is enabled (RAG_RERANK_ENABLED=1).
# On Windows with bleeding-edge Python, torch may fail to load (WinError 1114 / c10.dll) — set 0 to disable rerank.
# RAG_RERANK_ENABLED=0
# RAG_RERANK_TOP_K=5
# RAG_RERANKER_MODEL=BAAI/bge-reranker-large
# RAG_RERANKER_DEVICE=cpu

# ============================================================================
# Ask Consultant — structured progress logs (optional; default on)
# ============================================================================
# CONSULTANT_PROGRESS_LOG=0   # set 0/false/off to silence [consultant …] timing lines on the API process
# CONSULTANT_PROGRESS_VERBOSE=1   # longer field values + multi-line pinecone / tavily query dumps (detail | …)

# Hugging Face (reranker model download) — less console noise + optional auth
# ============================================================================
# HYEAERO_VERBOSE_MODEL_LOAD=1   # show full transformers / hub “Loading weights…” output again
# HF_TOKEN=hf_xxx                # https://huggingface.co/settings/tokens — removes unauthenticated warning + higher limits
# (defaults set in code: HF_HUB_DISABLE_PROGRESS_BARS=1)

# ============================================================================
# Ask Consultant — intent-filtered LLM context (optional)
# ============================================================================
# CONSULTANT_CONTEXT_MAX_TOKENS=1500          # approx token cap = min(API char budget, this * CHARS_PER_TOKEN)
# CONSULTANT_CONTEXT_CHARS_PER_TOKEN=4       # heuristic when tiktoken is not used
# CONSULTANT_CONTEXT_INTENT_FILTER_DISABLE=1 # set to include all section buckets regardless of intent
# CONSULTANT_IMAGE_INTENT_LLM=1              # hybrid image intent: 0 = keywords + follow-ups only (no LLM classifier); 1 = also run multi-class LLM when keywords miss
# CONSULTANT_IMAGE_INTENT_TIMEOUT_SEC=14     # OpenAI timeout for image-intent classifier (seconds)
# CONSULTANT_GALLERY_MAX_IMAGES=5            # max aircraft images per consultant reply (default 5 ≈ 3–5 photos; clamped 3–48; Tavily + listing galleries)
# CONSULTANT_CONVERSATION_GUARD_LLM=1        # optional: LLM refines guard types (greeting/small_talk/identity/aviation) before tool routing
# CONSULTANT_AVIATION_INTENT_MIN_CONFIDENCE=0.6   # LLM must score ≥ this to run aircraft DB / FAA / listings / RAG (else general-chat reply, no tools)
# CONSULTANT_LLM_TOOL_ROUTING_DISABLED=1     # optional: skip LLM tool-routing gate (rules-only; use when no API or debugging)

# ============================================================================
# Redis (optional) — caches completed Ask Consultant responses for 24h
# ============================================================================
# REDIS_URL=redis://localhost:6379/0
# RAG_ANSWER_CACHE_DISABLED=1
# RAG_ANSWER_CACHE_TTL_SEC=86400

# ============================================================================
# SearchAPI.io — Bing Images for Ask Consultant gallery (replaces Tavily image blobs when set)
# ============================================================================
# SEARCHAPI_API_KEY=

# ============================================================================
# Consultant query analytics — logs user questions to PostgreSQL (on by default with Postgres)
# ============================================================================
# CONSULTANT_QUERY_ANALYTICS_ENABLED=0   # optional: set to 0/false/no/off to stop logging new questions
# CONSULTANT_ANALYTICS_ADMIN_KEY=generate-a-long-random-secret
# CONSULTANT_RATE_LIMIT_ENABLED=1        # 0/false/off disables daily question cap (default: on)
# CONSULTANT_DAILY_USER_QUERY_LIMIT=10   # general users: max consultant questions per UTC day (admin/super_admin exempt)
# Optional. For curl/scripts only: send header X-Admin-Key: <same value>.
# The dashboard (/admin/queries) uses your admin JWT — you do NOT need this key for normal browser use.

# ============================================================================
# Dashboard auth (users in PostgreSQL ``app_users``)
# ============================================================================
# JWT_SECRET=long-random-string-at-least-16-chars
# JWT_EXPIRE_DAYS=7
#
# Super admin (created once when no super_admin exists yet — sign in after deploy to activate signups):
# SUPER_ADMIN_EMAIL=you@company.com
# SUPER_ADMIN_PASSWORD=min-8-chars
# SUPER_ADMIN_FULL_NAME=Your Name
# SUPER_ADMIN_COUNTRY=US
#
# Aliases (same behavior): BOOTSTRAP_SUPER_ADMIN_EMAIL, BOOTSTRAP_SUPER_ADMIN_PASSWORD, etc.
