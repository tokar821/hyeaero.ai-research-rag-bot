# HyeAero Backend - RAG Pipeline Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# PostgreSQL Configuration
# ============================================================================
# Either provide connection string OR individual components
POSTGRES_CONNECTION_STRING=postgres://user:password@host:port/database?sslmode=require
# OR use individual components:
# POSTGRES_HOST=your-postgres-host
# POSTGRES_PORT=5432
# POSTGRES_DATABASE=your-database-name
# POSTGRES_USER=your-postgres-user
# POSTGRES_PASSWORD=your-postgres-password

# ============================================================================
# Pinecone Configuration
# ============================================================================
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX_NAME=
PINECONE_DIMENSION=
PINECONE_METRIC=
PINECONE_REGION=

# ============================================================================
# OpenAI Configuration
# ============================================================================
OPENAI_API_KEY=
OPENAI_EMBEDDING_DIMENSION=

# ============================================================================
# RAG Pipeline Configuration (Optional - defaults shown)
# ============================================================================
# RAG_CHUNK_SIZE=1000
# RAG_CHUNK_OVERLAP=200
# RAG_BATCH_SIZE=100

# ============================================================================
# Ask Consultant — latency (optional)
# ============================================================================
# One switch — recommended if answers feel too slow (trades some depth/polish for speed):
# CONSULTANT_LOW_LATENCY=1
#   → skips query-expand LLM, one Tavily pass, smaller RAG, caps Tavily HTTP ~20s, skips review pass.
#
# Biggest single win for time-to-first-token: skip the second LLM pass (draft + polish).
# CONSULTANT_FAST_MODE=1
# CONSULTANT_REVIEW_DISABLED=1
#
# Retrieval / web search (stack with FAST_MODE / LOW_LATENCY as needed):
# CONSULTANT_FAST_RETRIEVAL=1          # one Tavily pass, fewer RAG variants/chunks, cap Tavily results
# CONSULTANT_SKIP_QUERY_EXPAND=1       # skip OpenAI JSON expand; use raw user query for Tavily + RAG
# CONSULTANT_TAVILY_SINGLE_PASS=1      # no owner-focus or purchase-merge Tavily passes (saves 1–2 HTTP calls)
# CONSULTANT_TAVILY_RESULTS_PER_PASS=6 # default 8; min 4 max 10
# CONSULTANT_TAVILY_TIMEOUT_SEC=28     # REST Tavily timeout when using requests fallback (seconds)
# CONSULTANT_RAG_QUERY_VARIANTS=3      # Pinecone paraphrases per request (default 5, max 8)
# CONSULTANT_RAG_ENRICH_MAX=6          # cap after purchase-biased query expansion (default 8)
# CONSULTANT_RAG_MAX_CHUNKS=14         # max unique vector hits (default 18)
# CONSULTANT_EXPAND_TIMEOUT_SEC=18     # OpenAI timeout for query-expand call (default 18)
# CONSULTANT_EXPAND_MODEL=gpt-4o-mini  # optional cheaper/faster model for expand only
#
# Tavily only when needed (skips web search when Phly+FAA already cover the question class):
# CONSULTANT_TAVILY_WHEN_NEEDED=1
#   Still runs Tavily for: purchase/price/listing, no Phly match, missing/partial FAA row,
#   operator/charter/fleet/management wording, news/website triggers. Otherwise skips (faster).
#
# Internal market SQL (listings + comps) — already skipped unless user text looks purchase/price/listing.
# Tighten further (fewer false triggers on words like "available" / "listed"):
# CONSULTANT_MARKET_SQL_STRICT=1
